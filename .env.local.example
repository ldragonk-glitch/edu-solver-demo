# 复制本文件为 .env.local 后填入你的 Anthropic API key
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxx

# 可选：覆盖默认模型 (默认 claude-sonnet-4-6)
# ANTHROPIC_MODEL=claude-opus-4-6

# 可选：隐藏模型切换 (?models=1) 使用
MODEL_PROVIDER_DEFAULT=claude
BIGMODEL_API_KEY=
BIGMODEL_BASE_URL=https://open.bigmodel.cn/api/paas/v4
BIGMODEL_MODEL=glm-5v-turbo
MOONSHOT_API_KEY=
MOONSHOT_BASE_URL=https://api.moonshot.cn/v1
KIMI_MODEL=kimi-k2.6

# 管理后台密码: 访问 /admin/usage?p=这个值 才能看用量仪表盘
# 不设的话 /admin/usage 公开可访问 (不推荐, demo 阶段也建议设)
ADMIN_PASSWORD=change-me-to-a-random-string
